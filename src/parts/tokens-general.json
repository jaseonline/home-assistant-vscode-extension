        }
    },
    {
        "name": "JSON - Property Keys",
        "scope": [
            "support.type.property-name.json"
        ],
        "settings": {
            "foreground": "#00b4ff"
        }
    },
    {
        "name": "YAML - Keys",
        "scope": [
