[
    {
        "name": "Comments (general)",
        "scope": [
            "comment",
            "punctuation.definition.comment"
        ],
        "settings": {
            "foreground": "#929292",
            "fontStyle": "italic"
        }
    },
    {
        "name": "Strings (general)",
        "scope": [
            "string"
        ],
        "settings": {
            "foreground": "#ffe600"
        }
    },
    {
        "name": "Numbers (general)",
        "scope": [
            "constant.numeric"
        ],
        "settings": {
            "foreground": "#c792ea"
        }
    },
    {
        "name": "Constants (general)",
        "scope": [
            "constant.language"
        ],
        "settings": {
            "foreground": "#00ff80"
        }
    },
    {
        "name": "Keywords",
        "scope": [
            "keyword",
            "storage.modifier",
            "storage.type"
        ],
        "settings": {
            "foreground": "#ff0080",
            "fontStyle": "bold"
        }
    },
    {
        "name": "Functions",
        "scope": [
            "entity.name.function",
            "support.function"
        ],
        "settings": {
            "foreground": "#ff9500"
        }
    },
    {
        "name": "Types and Classes",
        "scope": [
            "entity.name.type",
            "entity.name.class",
            "support.class",
            "entity.name.namespace"
        ],
        "settings": {
            "foreground": "#bbadff"
        }
    },
    {
        "name": "Variables",
        "scope": [
            "variable"
        ],
        "settings": {
            "foreground": "#00ffe7"
        }
    },
    {
        "name": "HTML/XML Tags",
        "scope": [
            "entity.name.tag"
        ],
        "settings": {
            "foreground": "#00b4ff"
        }
    },
    {
        "name": "HTML/XML Attributes",
        "scope": [
            "entity.other.attribute-name"
        ],
        "settings": {
            "foreground": "#ffe600"
        }
    },
    {
        "name": "Property Names",
        "scope": [
            "support.type.property-name"
        ],
        "settings": {
            "foreground": "#ffe600"
        }
    },
    {
        "name": "Brackets and Braces",
        "scope": [
            "punctuation.definition.bracket",
            "punctuation.section.array.begin",
            "punctuation.section.array.end",
            "punctuation.section.block.begin",
            "punctuation.section.block.end",
            "meta.brace.round",
            "meta.brace.square",
            "meta.brace.curly",
            "punctuation.parenthesis.begin",
            "punctuation.parenthesis.end",
            "punctuation.squarebracket.open",
            "punctuation.squarebracket.close",
            "punctuation.curlybrace.open",
            "punctuation.curlybrace.close"
        ],
        "settings": {
            "foreground": "#ff9500"
        }
    },
    {
        "name": "Punctuation (general)",
        "scope": [
            "punctuation"
        ],
        "settings": {
            "foreground": "#e8e8f0"
        }
    },
    {
        "name": "Operators (general)",
        "scope": [
            "keyword.operator"
        ],
        "settings": {
            "foreground": "#e8e8f0"
        }
    },
    {
        "name": "Escape Characters",
        "scope": [
            "constant.character.escape"
        ],
        "settings": {
            "foreground": "#00ff80"
        }
    },
    {
        "name": "Python - Magic Variables",
        "scope": [
            "support.variable.magic.python"
        ],
        "settings": {
            "foreground": "#bbadff"
        }
    },
    {
        "name": "Python - Self Parameter",
        "scope": [
            "variable.parameter.function.language.special.self.python"
        ],
        "settings": {
            "foreground": "#c792ea"
        }
    },
    {
        "name": "Python - Separators",
        "scope": [
            "punctuation.separator.period.python",
            "punctuation.separator.element.python",
            "punctuation.parenthesis.begin.python",
            "punctuation.parenthesis.end.python"
        ],
        "settings": {
            "foreground": "#ff9500"
        }
    },
    {
        "name": "JavaScript - This",
        "scope": [
            "variable.language.this"
        ],
        "settings": {
            "foreground": "#ff0080",
            "fontStyle": "bold"
        }
    },
    {
        "name": "JavaScript - Function Calls",
        "scope": [
            "meta.function-call"
        ],
        "settings": {
            "foreground": "#ff9500"
        }
    },
    {
        "name": "Jinja2 - Template Tags",
        "scope": [
            "entity.other.jinja.delimiter.tag",
            "entity.other.jinja.delimiter.variable"
        ],
        "settings": {
            "foreground": "#ff0080",
            "fontStyle": "bold"
        }
    },
    {
        "name": "Jinja2 - Template Variables",
        "scope": [
            "variable.other.jinja"
        ],
        "settings": {
            "foreground": "#c792ea"
        }
    },
    {
        "name": "Jinja2 - Template Keywords",
        "scope": [
            "keyword.control.jinja"
        ],
        "settings": {
            "foreground": "#ff0080",
            "fontStyle": "bold"
        }
    },
    {
        "name": "RegExp - Character Class",
        "scope": [
            "constant.other.character-class.regexp"
        ],
        "settings": {
            "foreground": "#00ff80"
        }
    },
    {
        "name": "RegExp - Quantifier",
        "scope": [
            "keyword.operator.quantifier.regexp"
        ],
        "settings": {
            "foreground": "#ff9500"
        }
    },
    {
        "name": "String Delimiters",
        "scope": [
            "punctuation.definition.string.begin",
            "punctuation.definition.string.end"
        ],
        "settings": {
            "foreground": "#ffe600"
        }
    },
    {
        "name": "Markdown - Headings",
        "scope": [
            "markup.heading"
        ],
        "settings": {
            "foreground": "#00b4ff",
            "fontStyle": "bold"
        }
    },
    {
        "name": "Markdown - Bold",
        "scope": [
            "markup.bold"
        ],
        "settings": {
            "foreground": "#e8e8f0",
            "fontStyle": "bold"
        }
    },
    {
        "name": "Markdown - Italic",
        "scope": [
            "markup.italic"
        ],
        "settings": {
            "foreground": "#e8e8f0",
            "fontStyle": "italic"
        }
    },
    {
        "name": "Markdown - Code",
        "scope": [
            "markup.inline.raw"
        ],
        "settings": {
