// Place your settings in this file to overwrite default and user settings.
{
    "files.exclude": {
        "out": false // set this to true to hide the "out" folder with the compiled JS files
    },
    "search.exclude": {
        "out": true // set this to false to include "out" folder in search results
    },
    // Turn off tsc task auto detection since we have the necessary tasks as npm scripts
    "js/ts.tsc.autoDetect": "off",
    "colorize.languages": [
        "css",
        "sass",
        "scss",
        "json",
        "less",
        "postcss",
        "sss",
        "stylus",
        "xml",
        "svg"
    ],
    "colorize.colorized_colors": [
        "BROWSERS_COLORS",
        "HEXA",
        "RGB",
        "HSL",
        "OKLAB",
        "OKLCH"
    ],
    "editor.quickSuggestions": {

        "other": "offWhenInlineCompletions",
        "comments": "off",
        "strings": "off"
    },
    "github.copilot.chat.agent.autoFix": true,
    "editor.inlineSuggest.experimental.showOnSuggestConflict": "always",
    "inlineChat.notebookAgent": true,
    "terminal.integrated.suggest.inlineSuggestion": "alwaysOnTopExceptExactMatch",
    "notebook.inlineValues": "on",
    "emmet.useInlineCompletions": true,
    "github.copilot.chat.languageContext.inline.typescript.enabled": true,
    "github.copilot.completions.chat.enabled": true
}